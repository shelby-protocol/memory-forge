{
  "name": "memory-forge",
  "version": "0.13.6",
  "description": "Forge persistent memories for your AI agent. 9 MCP tools + 5 auto-engines. Powered by Shelby decentralized cloud.",
  "type": "module",
  "license": "MIT",
  "author": "shelby-protocol",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shelby-protocol/memory-forge.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "memory",
    "persistent-memory",
    "vector-search",
    "embeddings",
    "claude-code",
    "cursor",
    "shelby",
    "decentralized-storage",
    "memory-forge"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "bin": {
    "memory-forge": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "TECHNICAL.md",
    "TUTORIAL.md",
    "CHANGELOG.md",
    "article-devto.md",
    "results-hybrid-hybrid.json",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "npx tsx bench/benchmark.ts",
    "bench:bm25": "npx tsx bench/benchmark.ts --method bm25 --skip-embed",
    "bench:hybrid": "npx tsx bench/benchmark.ts --method hybrid",
    "test:coverage": "vitest run --coverage",
    "test:all": "vitest run",
    "lint": "npx eslint src/",
    "format": "npx prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "npx prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "@aptos-labs/ts-sdk": "^5.2.1",
    "@shelby-protocol/sdk": "^0.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "prettier": "^3.8.5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
